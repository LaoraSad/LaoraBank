print("---- BIENVENIDO A PELUQUERÍA LAORA----\n")

total_dia = 0

corte = 0
cepillado = 0
tintura = 0

for i in range(1,8,1):

    nombre = input(F"Nombre del cliente {i}:  ")

    print("\nServicios")
